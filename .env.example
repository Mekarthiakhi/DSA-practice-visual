# Frontend environment variables
VITE_API_URL=http://localhost:3001
VITE_ENVIRONMENT=development

# Optional isolated trace endpoint for Java/C/C++/C#/Go/Rust. This may point
# to the backend proxy, for example http://localhost:3001/api/execute.
# It must accept POST { code, language, trace: true, maxSteps } and return
# { steps: ExecutionStep[], output: string[], error?: string }.
VITE_EXECUTION_API_URL=

# Optional anonymous, opt-in runtime metrics endpoint. Defaults to /api/telemetry.
VITE_TELEMETRY_ENDPOINT=/api/telemetry

# Backend server will use PORT env var for deployment
